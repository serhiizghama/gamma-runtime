# ── OpenClaw Gateway ──────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# Gateway Authorization Scopes (Comma-separated)
# operator.admin is required for device auth to bypass scope check
GATEWAY_SCOPES="operator.admin,operator.write,operator.read"

# ── Device Identity (Ed25519) ────────────────────────────
GAMMA_DEVICE_ID=gamma-runtime-bridge-001
GAMMA_DEVICE_PUBLIC_KEY=
GAMMA_DEVICE_PRIVATE_KEY=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Gamma Runtime Repo ───────────────────────────────────
GAMMA_RUNTIME_REPO=/path/to/gamma-runtime

# ── Git Author ────────────────────────────────────────────
GIT_AUTHOR_NAME=your-github-username
GIT_AUTHOR_EMAIL=your@email.com

# ── Scaffold — Smart Commit (v1.5) ───────────────────────
SCAFFOLD_GIT_BRANCH=private-apps
SCAFFOLD_AUTO_PUSH=false
SCAFFOLD_PRIVATE_REPO_URL=

# ── Session GC (v1.6) ─────────────────────────────────────
SESSION_GC_TTL_HOURS=24

# ── Server ────────────────────────────────────────────────
PORT=3001
