{
  "name": "gamma-runtime",
  "private": true,
  "version": "0.1.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @gamma/ui dev",
    "dev:core": "pnpm --filter @gamma/core start:dev",
    "build:types": "pnpm --filter @gamma/types build",
    "build:core": "pnpm run build:types && pnpm --filter @gamma/core build",
    "build:ui": "pnpm run build:types && pnpm --filter @gamma/ui build",
    "build": "pnpm run build:types && pnpm --filter @gamma/core build && pnpm --filter @gamma/ui build && pnpm --filter @gamma/watchdog build",
    "start:core": "pnpm --filter @gamma/core start:prod",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm run build:types && pnpm -r --if-present run typecheck"
  }
}
